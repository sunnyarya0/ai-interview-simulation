# AI Interview Simulator — backend environment variables
# Copy this file to .env and fill in values for your local machine.

# SQLite database file path (relative to backend/ directory)
DATABASE_URL=sqlite+aiosqlite:///./interview.db

# Redis connection string (start with: docker compose up -d)
REDIS_URL=redis://localhost:6379/0

# Directory where uploaded resumes are saved (relative to backend/)
UPLOAD_DIR=./uploads

# Ollama API base URL (Ollama must be running: ollama serve)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model used for resume structuring and the interview (ollama pull <model>)
OLLAMA_MODEL=llama3.2

# Chroma persistent storage directory (relative to backend/)
CHROMA_PATH=./chroma_db

# Speech-to-text (faster-whisper). Model downloads from HuggingFace on first use.
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Text-to-speech engine: "say" (macOS built-in) or "piper" (cross-platform, needs piper-tts)
TTS_ENGINE=say
PIPER_VOICE_PATH=./voices/en_US-lessac-medium.onnx

# Number of Q&A pairs before the AI wraps up the interview
MAX_INTERVIEW_TURNS=6

# Allowed browser origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
